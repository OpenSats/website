# generated OG images (built by scripts/generate-*-og.mjs at build time).
# og-default.png is intentionally tracked as a brand fallback so the site
# always has a working share image even if the generation pipeline breaks
# (font issues, resvg regression, etc.).
/public/static/images/projects/og/
/public/static/images/newsletter/og/
/public/static/images/funds/og/
/public/static/images/pages/og/
/public/static/images/authors/og/
/public/static/images/topics/og/
/public/static/images/heartbeat/og.png

# misc
.DS_Store

# debug
*.log
npm-debug.log*

# local env files
.env.local
.env.development.local
.env.test.local
.env.production.local

# Contentlayer
.contentlayer

# TypeScript
*.tsbuildinfo

# VSCode
.vscode
